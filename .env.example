# ─────────────────────────────────────────────────────────────
# Crow Repuestos — Variables de entorno requeridas
# Copiá este archivo a .env y completá los valores antes de
# levantar el stack con: docker compose up --build
# ─────────────────────────────────────────────────────────────

# REQUERIDO — Clave secreta para firmar los JWT.
# Generá una con: openssl rand -hex 32
SECRET_KEY=

# REQUERIDO — Contraseña del usuario administrador inicial (seed).
# Debe cumplir la política: 10+ chars, mayúscula, minúscula, dígito y caracter especial.
SEED_ADMIN_PASSWORD=

# Opcionales — se usan estos valores por defecto si no se definen.
SEED_ADMIN_EMAIL=admin@crowrepuestos.com
SEED_USER_EMAIL=cliente@crowrepuestos.com
SEED_USER_PASSWORD=cliente1234

# IPs de los proxies reversos de confianza (nginx, load balancer).
# Sin esto, el header X-Forwarded-For se ignora y el rate limiter usa la IP directa.
# En producción: docker inspect <nginx-container> | grep IPAddress
# Ejemplo: TRUSTED_PROXIES=172.18.0.3
TRUSTED_PROXIES=
