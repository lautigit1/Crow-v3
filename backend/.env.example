# Copy to .env for local development. Never commit .env to version control.
# Docker reads these from docker-compose.yml.

# ── Project ────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://crow:crow_dev_password@localhost:5432/crow_repuestos
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ───────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Redis ──────────────────────────────────────────────────────────────────
# Leave empty to use in-memory fallback (dev default).
# With docker-compose: redis://crow_redis:6379/0
# With Redis Cloud / Upstash: rediss://:password@host:port/0
REDIS_URL=

# ── Rate limiting ──────────────────────────────────────────────────────────
QUOTE_RATE_LIMIT=5       # max public quote submissions per window
QUOTE_RATE_WINDOW=3600   # window in seconds (1 hour)

# ── Seed (dev only) ────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@crowrepuestos.com
SEED_ADMIN_PASSWORD=admin1234
SEED_USER_EMAIL=cliente@crowrepuestos.com
SEED_USER_PASSWORD=cliente1234
